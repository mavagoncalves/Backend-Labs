<!DOCTYPE html>
<html>
<head><title>Task Details</title></head>
<body>
    <a href="/tasks">Back to Tasks</a>
    <h1>Task Details</h1>
    
    <p><strong>ID:</strong> <%= task._id %></p>
    <p><strong>Title:</strong> <%= task.title %></p>
    <p><strong>Status:</strong> <%= task.completed ? "Done" : "Pending" %></p>
    
    <a href="/tasks/<%= task._id %>/edit">Edit this Task</a>
</body>
</html>